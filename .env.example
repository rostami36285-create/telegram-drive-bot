# ════════════════════════════════════════════════════════
#  Telegram Drive Bot — فایل تنظیمات
#  install.sh بیشتر این مقادیر را خودکار پر می‌کند
# ════════════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# شناسه عددی ادمین‌ها — از @userinfobot بگیرید
ADMIN_IDS=123456789

# کانال‌های اجباری — اختیاری، قابل مدیریت از پنل ادمین
REQUIRED_CHANNELS=

# ── Google Drive API (App Credentials — نه حساب شخصی) ────────
#
#  این مقادیر برای ساخت OAuth flow برای کاربران لازم است.
#  هر کاربر با حساب Google خودش وارد می‌شود — ادمین نیازی به
#  اتصال Drive خودش ندارد.
#
#  راهنما:
#   ۱. console.cloud.google.com → پروژه جدید
#   ۲. APIs & Services → Enable: Google Drive API
#   ۳. Credentials → Create OAuth 2.0 Client ID (Web application)
#   ۴. Authorized redirect URI: https://YOUR_DOMAIN/oauth/callback
#   ۵. مقادیر زیر را از Google کپی کنید:
#
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ── SSL + Webhook (توسط install.sh پر می‌شود) ────────────────
WEBHOOK_URL=
WEBHOOK_SECRET=
OAUTH_REDIRECT_URI=

# ── امنیت — توسط install.sh خودکار تولید می‌شود ─────────────
ENCRYPTION_KEY=your_fernet_key_here

# ── دیتابیس ──────────────────────────────────────────────────
DATABASE_PATH=bot.db

# ── محدودیت آپلود ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=4096
DAILY_UPLOAD_LIMIT=5
MAX_CONCURRENT_UPLOADS=3
MAX_QUEUE_SIZE=50

# ── آنتی اسپم ─────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW=10

# ── سرور داخلی (پشت Nginx — دست نزنید) ──────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
