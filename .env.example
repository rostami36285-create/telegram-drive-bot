# Telegram Bot Token — از @BotFather بگیرید
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google OAuth — از Google Cloud Console بگیرید
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# آدرس callback که در Google Cloud Console ثبت می‌کنید
# برای تست محلی:  http://localhost:8080/oauth/callback
# برای سرور:      https://yourdomain.com/oauth/callback
OAUTH_REDIRECT_URI=http://localhost:8080/oauth/callback

# تنظیمات سرور
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# حداکثر حجم فایل قابل آپلود (مگابایت)
MAX_FILE_SIZE_MB=500

# مسیر دیتابیس SQLite
DATABASE_PATH=bot.db
